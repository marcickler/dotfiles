# Shared shell functions for Bash and Zsh.
# Keep this file portable across both shells.

# Count regular files and directories in the top level of a path (non-recursive).
ct() {
    ct_dir="${1:-.}"
    if [ ! -d "$ct_dir" ]; then
        printf 'ct: not a directory: %s\n' "$ct_dir" >&2
        return 1
    fi

    find "$ct_dir" -mindepth 1 -maxdepth 1 -printf '%y\n' 2>/dev/null | awk '
        BEGIN { files = 0; dirs = 0 }
        $1 == "f" { files++ }
        $1 == "d" { dirs++ }
        END {
            printf "files:\t%d\n", files
            printf "dirs:\t%d\n", dirs
            printf "total:\t%d\n", files + dirs
        }
    '
}

# Smart tmux entrypoint: create/attach directly when unambiguous, otherwise list sessions.
tmx() {
    tmux_output="$(tmux ls 2>&1)"
    tmux_status=$?

    if [ "$tmux_status" -ne 0 ]; then
        case "$tmux_output" in
            *"no server running"*|*"error connecting to "*"(No such file or directory)"*)
                tmux
                return $?
                ;;
            *)
                printf '%s\n' "$tmux_output" >&2
                return "$tmux_status"
                ;;
        esac
    fi

    tmux_sessions=$(printf '%s\n' "$tmux_output" | awk 'NF { count++ } END { print count + 0 }')
    if [ "$tmux_sessions" -eq 1 ]; then
        tmux attach
        return $?
    fi

    printf '%s\n' "$tmux_output"
}
